# Supabase - client
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Supabase - server/admin
# Never expose this value in the browser.
# Required for public intake, public chat, inbound email, inbound WhatsApp and invitation registration routes.
SUPABASE_SECRET_KEY=

# Inquiry analysis engine
# local = rule-based fallback engine
# ai = OpenAI engine with automatic fallback to local
COPPE_INQUIRY_ANALYSIS_ENGINE=local

# OpenAI
# Required only when COPPE_INQUIRY_ANALYSIS_ENGINE=ai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_REQUEST_TIMEOUT_MS=15000
OPENAI_MAX_OUTPUT_TOKENS=1200

# Inbound email
# Secret expected by /api/inbound-email.
INBOUND_EMAIL_WEBHOOK_SECRET=

# Resend inbound email webhook
# Required by /api/inbound-email/resend.
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=
RESEND_REQUEST_TIMEOUT_MS=15000

# WhatsApp Business Cloud API inbound webhook
# Verification token expected by Meta during webhook setup.
WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# App secret used to verify inbound WhatsApp signatures.
WHATSAPP_APP_SECRET=

# WhatsApp Business Cloud API outbound sending
# Required by /api/inquiries/send-whatsapp-response.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_GRAPH_API_VERSION=v23.0
WHATSAPP_REQUEST_TIMEOUT_MS=15000
WHATSAPP_THREAD_WINDOW_DAYS=30
PUBLIC_CHAT_SESSION_DAYS=30
NEXT_PUBLIC_COPPE_INBOUND_EMAIL_DOMAIN=inbound.coppe.es

# Optional deployment identifier returned by /api/health.
COPPE_RELEASE=
