# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Inquiry analysis engine
# local = rule-based fallback engine
# ai = OpenAI engine with automatic fallback to local
COPPE_INQUIRY_ANALYSIS_ENGINE=local

# OpenAI
# Required only when COPPE_INQUIRY_ANALYSIS_ENGINE=ai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_REQUEST_TIMEOUT_MS=15000
OPENAI_MAX_OUTPUT_TOKENS=1200
